import java.util.*;
public class Tarzo {
    public static void main(String[] args) {
        int n,i,j,count;
        Scanner s= new Scanner(System.in);
        count = 0;
        n=s.nextInt();
        i=s.nextInt();
        for(j=i;j<=n;j++){
            if(j<=n){
                count++;
            }
        }System.out.println(count);
        
    }
}
       
