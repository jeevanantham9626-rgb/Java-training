import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int num = sc.nextInt();     
        double d = sc.nextDouble();  
        sc.nextLine();               
        String str = sc.nextLine();  

        System.out.println(num);
        System.out.println(d);
        System.out.println(str);

        sc.close();
    }
}
