import java.util.*;
public class Tarzo {
    public static void main(String[] args) { 
        int n,dig,m;
        Scanner s = new Scanner(System.in);
        n = s.nextInt();
        dig = 1;
        while(n>0){
            m=n%10;
            dig = dig*m;
            n = n/10;
        }
        System.out.println(dig);
    }
}
