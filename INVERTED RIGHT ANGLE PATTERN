import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
       int a;
        Scanner s= new Scanner(System.in);
        a=s.nextInt();
        for(int i=a;i>=1;i--){
            for(int j=i;j>=1;j--){
                System.out.print("*");
            }
            System.out.println();
        }
    }
}
