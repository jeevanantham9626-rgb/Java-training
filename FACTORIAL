import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
      int a;
        Scanner s= new Scanner(System.in);
       a = s.nextInt();
        int factorial=1;
        for(int i=1;i<=a;i++)
        {
            factorial=factorial*i;
        }
        System.out.println(factorial);
    }
}
